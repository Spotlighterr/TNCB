# =========================================================================
# FINDX - TNCB BACKEND ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to '.env' and fill in your actual private credentials.
# DO NOT commit your actual '.env' file containing real passwords to GitHub!
# =========================================================================

# Server Configuration
PORT=5000

# Database Configuration (Change to your MongoDB Atlas connection string in production)
MONGODB_URI=mongodb://localhost:27017/tncb

# Authentication Config
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Google OAuth Config (SSO)
GOOGLE_CLIENT_ID=your_google_client_id_here

